# ClinicFlow Configuration
# Copy this file to .env and adjust values as needed.

# Path to SQLite database file (use ":memory:" for in-memory)
CLINICFLOW_DB_PATH=clinicflow.db

# Default appointment duration in minutes
CLINICFLOW_DEFAULT_DURATION=30

# Default slot interval in minutes (for availability search)
CLINICFLOW_SLOT_INTERVAL=15

# Log level (DEBUG, INFO, WARNING, ERROR)
CLINICFLOW_LOG_LEVEL=INFO
